{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "instacomic",
  "main": "src/worker.ts",
  "compatibility_date": "2026-05-22",
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application"
  },
  "routes": [
    {
      "pattern": "instacomic.catcafe.space",
      "custom_domain": true
    }
  ],
  "observability": {
    "enabled": true
  }
}
